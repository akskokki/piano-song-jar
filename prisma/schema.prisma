generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Song {
  id             String         @id @default(cuid())
  title          String
  hands          Int            @default(2)
  createdAt      DateTime       @default(now()) @db.Timestamptz(3)
  songActivities SongActivity[]
}

model SongActivity {
  id        String           @id @default(cuid())
  songId    String
  type      SongActivityType
  createdAt DateTime         @default(now()) @db.Timestamptz(3)
  song      Song             @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId])
  @@index([songId, type, createdAt])
}

enum SongActivityType {
  played
  skipped
}
